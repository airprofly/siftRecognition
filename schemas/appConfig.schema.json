{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AppConfig",
  "description": "应用级配置文件，包含路径、日志等配置",
  "type": "object",
  "properties": {
    "paths": {
      "type": "object",
      "description": "路径相关配置",
      "properties": {
        "data_dir": {
          "type": "string",
          "description": "图像数据目录路径"
        },
        "ground_truth_dir": {
          "type": "string",
          "description": "Ground truth 数据目录路径"
        },
        "output": {
          "type": "object",
          "description": "输出目录结构配置",
          "properties": {
            "output_dir": {
              "type": "string",
              "description": "输出根目录路径"
            },
            "figure_dir": {
              "type": "string",
              "description": "图片子目录名（相对 output_dir）"
            }
          }
        },
        "image_pairs": {
          "type": "array",
          "description": "图像对列表",
          "items": {
            "type": "object",
            "properties": {
              "src_path": {
                "type": "string",
                "description": "第一张源图像的文件名"
              },
              "dst_path": {
                "type": "string",
                "description": "第二张目标图像的文件名"
              },
              "gt_path": {
                "type": "string",
                "description": "对应的 ground truth 文件名"
              }
            },
            "required": ["src_path", "dst_path", "gt_path"]
          }
        }
      }
    },
    "scene": {
      "type": "object",
      "description": "场景识别数据集路径配置",
      "properties": {
        "data_dir": {
          "type": "string",
          "description": "场景识别数据根目录，包含 train/ 和 test/ 子目录"
        }
      }
    },
    "scene_rec": {
      "type": "object",
      "description": "场景识别管道超参数和缓存配置",
      "properties": {
        "vocab_size": {
          "type": "integer",
          "description": "视觉词表大小（k-means 聚类数），默认 100"
        },
        "cache_dir": {
          "type": "string",
          "description": "特征和词表缓存目录，默认 ./data"
        },
        "k_tiny_images": {
          "type": "integer",
          "description": "Tiny Image 管道的 k-NN k 值，默认 3"
        },
        "k_bag_of_sifts": {
          "type": "integer",
          "description": "BoF 管道的 k-NN k 值，默认 15"
        },
        "svm_c": {
          "type": "number",
          "description": "LinearSVM 正则化参数 C，默认 0.1"
        },
        "stride": {
          "type": "integer",
          "description": "密集 SIFT 采样的步长，默认 20"
        },
        "num_per_cat": {
          "type": "integer",
          "description": "每类训练图像数限制，默认 100"
        }
      }
    },
    "logging": {
      "type": "object",
      "description": "日志行为配置",
      "properties": {
        "log_dir": {
          "type": "string",
          "description": "日志输出目录路径"
        },
        "level": {
          "type": "string",
          "description": "日志级别，可选 DEBUG/INFO/WARNING/ERROR/CRITICAL",
          "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
        },
        "retention": {
          "type": "string",
          "description": "日志文件保留时间，支持自然语言格式（如 '7 days'）"
        },
        "file_pattern": {
          "type": "string",
          "description": "日志文件名模式，使用 loguru 时间格式化（如 '{time:YYYY-MM-DD}.log'）"
        }
      }
    }
  }
}
